rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All reads/writes go through the app's own auth logic (PIN/password stored in Firestore)
    // For production, lock this down further with Firebase Auth.
    // For now, allow all authenticated (via Firebase project API key restriction).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
